<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.school_administration_system.controller.AdminDashboardController"
            style="-fx-background-color: #E2F3FD;">

    <!-- ==================== SIDEBAR ==================== -->
    <left>
        <VBox fx:id="sidebarContainer" prefWidth="220" minWidth="50" maxWidth="220" style="-fx-background-color: #304F6D;" spacing="0">

            <!-- Barre titre -->
            <HBox fx:id="sidebarTitleBar" alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: #243d55; -fx-padding: 12 15 12 15; -fx-min-height: 45; -fx-max-height: 45;">
                <Label fx:id="sidebarIconLabel" text="" style="-fx-font-size: 16px; -fx-text-fill: #FFE1A0;"/>
                <Label fx:id="sidebarTitleLabel" text="ADMIN" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #E6E1DD;"/>
                <Region fx:id="sidebarSpacer" HBox.hgrow="ALWAYS"/>
                <Label text="☰" style="-fx-font-size: 18px; -fx-text-fill: #E6E1DD; -fx-cursor: hand;" onMouseClicked="#handleToggleSidebar"/>
            </HBox>

            <!-- Logo -->
            <VBox fx:id="sidebarLogo" alignment="CENTER" spacing="5"
                  style="-fx-min-height: 160; -fx-max-height: 180;">
                <padding>
                    <Insets top="15" bottom="15"/>
                </padding>
                <StackPane>
                    <Circle radius="33" style="-fx-fill: transparent; -fx-stroke: #E07D54; -fx-stroke-width: 3;"/>
                    <ImageView fitHeight="110" fitWidth="110" preserveRatio="true">
                        <image>
                            <Image url="@../assets/images/d.png" />
                        </image>
                    </ImageView>
                </StackPane>
            </VBox>

            <!-- Menu -->
            <ScrollPane fx:id="sidebarScrollPane" fitToWidth="true" hbarPolicy="NEVER"
                        style="-fx-background: #304F6D; -fx-background-color: #304F6D; -fx-border-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox fx:id="sidebarMenu" spacing="2" style="-fx-background-color: #304F6D; -fx-padding: 5 8 5 8;">

                    <!-- Accueil -->
                    <HBox fx:id="menuAccueil" alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 40; -fx-max-height: 40; -fx-background-radius: 8;"
                          onMouseClicked="#handleAccueil">
                        <padding><Insets top="0" right="12" bottom="0" left="14"/></padding>
                        <Label text="🏠" style="-fx-font-size: 14px;"/>
                        <Label text="Accueil" style="-fx-text-fill: #E6E1DD; -fx-font-size: 13px;"/>
                    </HBox>

                    <!-- Étudiants -->
                    <HBox fx:id="menuEtudiants" alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 40; -fx-max-height: 40; -fx-background-radius: 8;"
                          onMouseClicked="#handleEtudiants">
                        <padding><Insets top="0" right="12" bottom="0" left="14"/></padding>
                        <Label text="🎓" style="-fx-font-size: 14px;"/>
                        <Label text="Étudiants" style="-fx-text-fill: #E6E1DD; -fx-font-size: 13px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="›" style="-fx-text-fill: #899481; -fx-font-size: 16px;"/>
                    </HBox>
                    <VBox fx:id="subMenuEtudiants" managed="false" visible="false" style="-fx-background-color: #3d6080; -fx-background-radius: 6; -fx-padding: 4 0 4 0;">
                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-cursor: hand; -fx-min-height: 34; -fx-max-height: 34;"
                              onMouseClicked="#handleAjouterEtudiant">
                            <padding><Insets top="0" right="15" bottom="0" left="38"/></padding>
                            <Label text="+" style="-fx-text-fill: #899481; -fx-font-size: 11px;"/>
                            <Label text="Inscrire Étudiant" style="-fx-text-fill: #E6E1DD; -fx-font-size: 12px;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-cursor: hand; -fx-min-height: 34; -fx-max-height: 34;"
                              onMouseClicked="#handleListeEtudiants">
                            <padding><Insets top="0" right="15" bottom="0" left="38"/></padding>
                            <Label text="+" style="-fx-text-fill: #899481; -fx-font-size: 11px;"/>
                            <Label text="Liste Étudiants" style="-fx-text-fill: #E6E1DD; -fx-font-size: 12px;"/>
                        </HBox>
                    </VBox>

                    <!-- Classes -->
                    <HBox fx:id="menuClasses" alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 40; -fx-max-height: 40; -fx-background-radius: 8;"
                          onMouseClicked="#handleClasses">
                        <padding><Insets top="0" right="12" bottom="0" left="14"/></padding>
                        <Label text="📖" style="-fx-font-size: 14px;"/>
                        <Label text="Classes" style="-fx-text-fill: #E6E1DD; -fx-font-size: 13px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="›" style="-fx-text-fill: #899481; -fx-font-size: 16px;"/>
                    </HBox>
                    <VBox fx:id="subMenuClasses" managed="false" visible="false" style="-fx-background-color: #3d6080; -fx-background-radius: 6; -fx-padding: 4 0 4 0;">
                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-cursor: hand; -fx-min-height: 34; -fx-max-height: 34;"
                              onMouseClicked="#handleCreerClasse">
                            <padding><Insets top="0" right="15" bottom="0" left="38"/></padding>
                            <Label text="+" style="-fx-text-fill: #899481; -fx-font-size: 11px;"/>
                            <Label text="Créer Classe" style="-fx-text-fill: #E6E1DD; -fx-font-size: 12px;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-cursor: hand; -fx-min-height: 34; -fx-max-height: 34;"
                              onMouseClicked="#handleListeClasses">
                            <padding><Insets top="0" right="15" bottom="0" left="38"/></padding>
                            <Label text="+" style="-fx-text-fill: #899481; -fx-font-size: 11px;"/>
                            <Label text="Liste Classes" style="-fx-text-fill: #E6E1DD; -fx-font-size: 12px;"/>
                        </HBox>
                    </VBox>

                    <!-- Enseignants -->
                    <HBox fx:id="menuEnseignants" alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 40; -fx-max-height: 40; -fx-background-radius: 8;"
                          onMouseClicked="#handleEnseignants">
                        <padding><Insets top="0" right="12" bottom="0" left="14"/></padding>
                        <Label text="👨‍🏫" style="-fx-font-size: 14px;"/>
                        <Label text="Enseignants" style="-fx-text-fill: #E6E1DD; -fx-font-size: 13px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="›" style="-fx-text-fill: #899481; -fx-font-size: 16px;"/>
                    </HBox>
                    <VBox fx:id="subMenuEnseignants" managed="false" visible="false" style="-fx-background-color: #3d6080; -fx-background-radius: 6; -fx-padding: 4 0 4 0;">
                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-cursor: hand; -fx-min-height: 34; -fx-max-height: 34;"
                              onMouseClicked="#handleAffecterEnseignant">
                            <padding><Insets top="0" right="15" bottom="0" left="38"/></padding>
                            <Label text="+" style="-fx-text-fill: #899481; -fx-font-size: 11px;"/>
                            <Label text="Affecter Enseignant" style="-fx-text-fill: #E6E1DD; -fx-font-size: 12px;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-cursor: hand; -fx-min-height: 34; -fx-max-height: 34;"
                              onMouseClicked="#handleListeEnseignants">
                            <padding><Insets top="0" right="15" bottom="0" left="38"/></padding>
                            <Label text="+" style="-fx-text-fill: #899481; -fx-font-size: 11px;"/>
                            <Label text="Liste Enseignants" style="-fx-text-fill: #E6E1DD; -fx-font-size: 12px;"/>
                        </HBox>
                    </VBox>

                    <!-- Emploi du temps -->
                    <HBox fx:id="menuEmploiDuTemps" alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 40; -fx-max-height: 40; -fx-background-radius: 8;"
                          onMouseClicked="#handleEmploiDuTemps">
                        <padding><Insets top="0" right="12" bottom="0" left="14"/></padding>
                        <Label text="📅" style="-fx-font-size: 14px;"/>
                        <Label text="Emploi du temps" style="-fx-text-fill: #E6E1DD; -fx-font-size: 13px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="›" style="-fx-text-fill: #899481; -fx-font-size: 16px;"/>
                    </HBox>
                    <VBox fx:id="subMenuEmploiDuTemps" managed="false" visible="false" style="-fx-background-color: #3d6080; -fx-background-radius: 6; -fx-padding: 4 0 4 0;">
                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-cursor: hand; -fx-min-height: 34; -fx-max-height: 34;"
                              onMouseClicked="#handleCreerEmploiDuTemps">
                            <padding><Insets top="0" right="15" bottom="0" left="38"/></padding>
                            <Label text="+" style="-fx-text-fill: #899481; -fx-font-size: 11px;"/>
                            <Label text="Créer Emploi du temps" style="-fx-text-fill: #E6E1DD; -fx-font-size: 12px;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-cursor: hand; -fx-min-height: 34; -fx-max-height: 34;"
                              onMouseClicked="#handleVoirEmploiDuTemps">
                            <padding><Insets top="0" right="15" bottom="0" left="38"/></padding>
                            <Label text="+" style="-fx-text-fill: #899481; -fx-font-size: 11px;"/>
                            <Label text="Voir Emploi du temps" style="-fx-text-fill: #E6E1DD; -fx-font-size: 12px;"/>
                        </HBox>
                    </VBox>

                    <!-- Communication -->
                    <HBox fx:id="menuCommunication" alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 40; -fx-max-height: 40; -fx-background-radius: 8;"
                          onMouseClicked="#handleCommunication">
                        <padding><Insets top="0" right="12" bottom="0" left="14"/></padding>
                        <Label text="✉" style="-fx-font-size: 14px;"/>
                        <Label text="Communication" style="-fx-text-fill: #E6E1DD; -fx-font-size: 13px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="›" style="-fx-text-fill: #899481; -fx-font-size: 16px;"/>
                    </HBox>
                    <VBox fx:id="subMenuCommunication" managed="false" visible="false" style="-fx-background-color: #3d6080; -fx-background-radius: 6; -fx-padding: 4 0 4 0;">
                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-cursor: hand; -fx-min-height: 34; -fx-max-height: 34;"
                              onMouseClicked="#handleEnvoyerMails">
                            <padding><Insets top="0" right="15" bottom="0" left="38"/></padding>
                            <Label text="+" style="-fx-text-fill: #899481; -fx-font-size: 11px;"/>
                            <Label text="Envoyer des Mails" style="-fx-text-fill: #E6E1DD; -fx-font-size: 12px;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-cursor: hand; -fx-min-height: 34; -fx-max-height: 34;"
                              onMouseClicked="#handleListerContacts">
                            <padding><Insets top="0" right="15" bottom="0" left="38"/></padding>
                            <Label text="+" style="-fx-text-fill: #899481; -fx-font-size: 11px;"/>
                            <Label text="Lister Contacts" style="-fx-text-fill: #E6E1DD; -fx-font-size: 12px;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-cursor: hand; -fx-min-height: 34; -fx-max-height: 34;"
                              onMouseClicked="#handleEnvoyerSMS">
                            <padding><Insets top="0" right="15" bottom="0" left="38"/></padding>
                            <Label text="+" style="-fx-text-fill: #899481; -fx-font-size: 11px;"/>
                            <Label text="Envoyer des SMS" style="-fx-text-fill: #E6E1DD; -fx-font-size: 12px;"/>
                        </HBox>
                    </VBox>

                    <!-- Paiements -->
                    <HBox fx:id="menuPaiements" alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 40; -fx-max-height: 40; -fx-background-radius: 8;"
                          onMouseClicked="#handlePaiements">
                        <padding><Insets top="0" right="12" bottom="0" left="14"/></padding>
                        <Label text="💰" style="-fx-font-size: 14px;"/>
                        <Label text="Paiements" style="-fx-text-fill: #E6E1DD; -fx-font-size: 13px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="›" style="-fx-text-fill: #899481; -fx-font-size: 16px;"/>
                    </HBox>
                    <VBox fx:id="subMenuPaiements" managed="false" visible="false" style="-fx-background-color: #3d6080; -fx-background-radius: 6; -fx-padding: 4 0 4 0;">
                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-cursor: hand; -fx-min-height: 34; -fx-max-height: 34;"
                              onMouseClicked="#handleNouveauPaiement">
                            <padding><Insets top="0" right="15" bottom="0" left="38"/></padding>
                            <Label text="+" style="-fx-text-fill: #899481; -fx-font-size: 11px;"/>
                            <Label text="Nouveau Paiement" style="-fx-text-fill: #E6E1DD; -fx-font-size: 12px;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-cursor: hand; -fx-min-height: 34; -fx-max-height: 34;"
                              onMouseClicked="#handleListePaiements">
                            <padding><Insets top="0" right="15" bottom="0" left="38"/></padding>
                            <Label text="+" style="-fx-text-fill: #899481; -fx-font-size: 11px;"/>
                            <Label text="Liste Paiements" style="-fx-text-fill: #E6E1DD; -fx-font-size: 12px;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-cursor: hand; -fx-min-height: 34; -fx-max-height: 34;"
                              onMouseClicked="#handleGenererFacture">
                            <padding><Insets top="0" right="15" bottom="0" left="38"/></padding>
                            <Label text="+" style="-fx-text-fill: #899481; -fx-font-size: 11px;"/>
                            <Label text="Générer Facture" style="-fx-text-fill: #E6E1DD; -fx-font-size: 12px;"/>
                        </HBox>
                    </VBox>

                    <!-- Suivi Activité Enseignants -->
                    <HBox fx:id="menuSuiviActivite" alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 40; -fx-max-height: 40; -fx-background-radius: 8;"
                          onMouseClicked="#handleSuiviActivite">
                        <padding><Insets top="0" right="12" bottom="0" left="14"/></padding>
                        <Label text="📑" style="-fx-font-size: 14px;"/>
                        <Label text="Suivi Activité" style="-fx-text-fill: #E6E1DD; -fx-font-size: 13px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="›" style="-fx-text-fill: #899481; -fx-font-size: 16px;"/>
                    </HBox>
                    <VBox fx:id="subMenuSuiviActivite" managed="false" visible="false" style="-fx-background-color: #3d6080; -fx-background-radius: 6; -fx-padding: 4 0 4 0;">
                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-cursor: hand; -fx-min-height: 34; -fx-max-height: 34;"
                              onMouseClicked="#handlePresencesAdmin">
                            <padding><Insets top="0" right="15" bottom="0" left="38"/></padding>
                            <Label text="✅" style="-fx-text-fill: #899481; -fx-font-size: 11px;"/>
                            <Label text="Présences" style="-fx-text-fill: #E6E1DD; -fx-font-size: 12px;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-cursor: hand; -fx-min-height: 34; -fx-max-height: 34;"
                              onMouseClicked="#handleRapportsAdmin">
                            <padding><Insets top="0" right="15" bottom="0" left="38"/></padding>
                            <Label text="📋" style="-fx-text-fill: #899481; -fx-font-size: 11px;"/>
                            <Label text="Rapports de séance" style="-fx-text-fill: #E6E1DD; -fx-font-size: 12px;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-cursor: hand; -fx-min-height: 34; -fx-max-height: 34;"
                              onMouseClicked="#handleCahierAdmin">
                            <padding><Insets top="0" right="15" bottom="0" left="38"/></padding>
                            <Label text="📝" style="-fx-text-fill: #899481; -fx-font-size: 11px;"/>
                            <Label text="Cahier de texte" style="-fx-text-fill: #E6E1DD; -fx-font-size: 12px;"/>
                        </HBox>
                    </VBox>

                    <!-- Matières -->
                    <HBox fx:id="menuMatieres" alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 40; -fx-max-height: 40; -fx-background-radius: 8;"
                          onMouseClicked="#handleMatieres">
                        <padding><Insets top="0" right="12" bottom="0" left="14"/></padding>
                        <Label text="📚" style="-fx-font-size: 14px;"/>
                        <Label text="Matières" style="-fx-text-fill: #E6E1DD; -fx-font-size: 13px;"/>
                    </HBox>

                    <!-- Statistiques -->
                    <HBox fx:id="menuStatistiques" alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 40; -fx-max-height: 40; -fx-background-radius: 8;"
                          onMouseClicked="#handleStatistiques">
                        <padding><Insets top="0" right="12" bottom="0" left="14"/></padding>
                        <Label text="📊" style="-fx-font-size: 14px;"/>
                        <Label text="Statistiques" style="-fx-text-fill: #E6E1DD; -fx-font-size: 13px;"/>
                    </HBox>

                    <Region VBox.vgrow="ALWAYS"/>

                    <!-- Déconnexion -->
                    <HBox alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 40; -fx-max-height: 40; -fx-background-radius: 8;"
                          onMouseClicked="#handleLogout">
                        <padding><Insets top="0" right="12" bottom="15" left="14"/></padding>
                        <Label text="🚪" style="-fx-font-size: 14px;"/>
                        <Label text="Déconnexion" style="-fx-text-fill: #E07D54; -fx-font-size: 13px;"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </left>

    <!-- ==================== CONTENU ==================== -->
    <center>
        <VBox style="-fx-background-color: #E2F3FD;">
            <!-- Barre supérieure -->
            <HBox alignment="CENTER_RIGHT" spacing="15"
                  style="-fx-background-color: white; -fx-border-color: #E6E1DD; -fx-border-width: 0 0 1 0; -fx-padding: 8 20 8 20; -fx-min-height: 45; -fx-max-height: 45;">
                <Region HBox.hgrow="ALWAYS"/>
                <StackPane style="-fx-cursor: hand;" onMouseClicked="#handleNotifications">
                    <Label text="🔔" style="-fx-font-size: 18px;"/>
                </StackPane>
                <StackPane style="-fx-cursor: hand;">
                    <Circle radius="16" style="-fx-fill: #E2F3FD;"/>
                    <Label text="👤" style="-fx-font-size: 14px;"/>
                </StackPane>
            </HBox>

            <!-- Contenu dynamique -->
            <ScrollPane fitToWidth="true" fitToHeight="true"
                        style="-fx-background: #E2F3FD; -fx-background-color: #E2F3FD; -fx-border-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <StackPane fx:id="contentArea" style="-fx-background-color: #E2F3FD;">
                    <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
                </StackPane>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>
