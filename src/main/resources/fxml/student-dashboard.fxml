<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.school_administration_system.controller.StudentDashboardController"
            style="-fx-background-color: #e8e8e8;">

    <!-- ==================== SIDEBAR ==================== -->
    <left>
        <VBox prefWidth="220" minWidth="220" maxWidth="220" style="-fx-background-color: #2c3e6b;" spacing="0">

            <!-- Barre titre -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: #253357; -fx-padding: 12 15 12 15; -fx-min-height: 45; -fx-max-height: 45;">
                <Label text="⚙" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                <Label text="ÉTUDIANT" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="☰" style="-fx-font-size: 18px; -fx-text-fill: white; -fx-cursor: hand;"/>
            </HBox>

            <!-- Logo -->
            <VBox alignment="CENTER" spacing="5"
                  style="-fx-min-height: 160; -fx-max-height: 160;">
                <padding><Insets top="20" bottom="20"/></padding>
                <StackPane>
                    <Circle radius="33" style="-fx-fill: transparent; -fx-stroke: #8e44ad; -fx-stroke-width: 3;"/>
                    <ImageView fitHeight="110" fitWidth="110" preserveRatio="true">
                        <image>
                            <Image url="@../assets/images/d.png" />
                        </image>
                    </ImageView>
                </StackPane>
            </VBox>

            <!-- Menu -->
            <VBox spacing="0" VBox.vgrow="ALWAYS" style="-fx-background-color: #2c3e6b;">

                <!-- Accueil -->
                <HBox fx:id="menuAccueilStudent" alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: #7c3aed; -fx-cursor: hand; -fx-min-height: 42; -fx-max-height: 42;"
                      onMouseClicked="#handleTableauDeBord">
                    <padding><Insets top="0" right="15" bottom="0" left="20"/></padding>
                    <Label text="🏠" style="-fx-font-size: 14px;"/>
                    <Label text="Accueil" style="-fx-text-fill: white; -fx-font-size: 13px;"/>
                </HBox>

                <!-- Ma classe -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 42; -fx-max-height: 42;"
                      onMouseClicked="#handleMaClasse"
                      onMouseEntered="#handleMenuHover" onMouseExited="#handleMenuExit">
                    <padding><Insets top="0" right="15" bottom="0" left="20"/></padding>
                    <Label text="📖" style="-fx-font-size: 14px;"/>
                    <Label text="Ma classe" style="-fx-text-fill: #bdc3c7; -fx-font-size: 13px;"/>
                </HBox>

                <!-- Enseignants -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 42; -fx-max-height: 42;"
                      onMouseClicked="#handleEnseignants"
                      onMouseEntered="#handleMenuHover" onMouseExited="#handleMenuExit">
                    <padding><Insets top="0" right="15" bottom="0" left="20"/></padding>
                    <Label text="👥" style="-fx-font-size: 14px;"/>
                    <Label text="Enseignants" style="-fx-text-fill: #bdc3c7; -fx-font-size: 13px;"/>
                </HBox>

                <!-- Emploi du temps -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 42; -fx-max-height: 42;"
                      onMouseClicked="#handleEmploiDuTemps"
                      onMouseEntered="#handleMenuHover" onMouseExited="#handleMenuExit">
                    <padding><Insets top="0" right="15" bottom="0" left="20"/></padding>
                    <Label text="📅" style="-fx-font-size: 14px;"/>
                    <Label text="Emploi du temps" style="-fx-text-fill: #bdc3c7; -fx-font-size: 13px;"/>
                </HBox>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Déconnexion -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 42; -fx-max-height: 42;"
                      onMouseClicked="#handleLogout">
                    <padding><Insets top="0" right="15" bottom="20" left="20"/></padding>
                    <Label text="🚪" style="-fx-font-size: 14px;"/>
                    <Label text="Déconnexion" style="-fx-text-fill: #e74c3c; -fx-font-size: 13px;"/>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <!-- ==================== CONTENU ==================== -->
    <center>
        <VBox style="-fx-background-color: #e8e8e8;">
            <!-- Barre supérieure -->
            <HBox alignment="CENTER_RIGHT" spacing="15"
                  style="-fx-background-color: #f8f8f8; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0; -fx-padding: 8 20 8 20; -fx-min-height: 45; -fx-max-height: 45;">
                <Region HBox.hgrow="ALWAYS"/>
                <StackPane style="-fx-cursor: hand;" onMouseClicked="#handleNotifications">
                    <Label text="🔔" style="-fx-font-size: 18px;"/>
                </StackPane>
                <StackPane style="-fx-cursor: hand;">
                    <Circle radius="16" style="-fx-fill: #2c3e6b;"/>
                    <Label text="👤" style="-fx-font-size: 14px;"/>
                </StackPane>
            </HBox>

            <!-- Contenu scrollable -->
            <ScrollPane fitToWidth="true" fitToHeight="true"
                        style="-fx-background: #e8e8e8; -fx-background-color: #e8e8e8; -fx-border-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox fx:id="mainContent" spacing="20">
                    <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>

                    <!-- Bienvenue -->
                    <VBox spacing="4">
                        <Label fx:id="welcomeLabel" text="Bonjour, Trecy !"
                               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e6b;"/>
                        <Label text="Bienvenue sur votre espace étudiant"
                               style="-fx-text-fill: #636e72; -fx-font-size: 13px;"/>
                        <Label fx:id="dateLabel" text=""
                               style="-fx-text-fill: #b2bec3; -fx-font-size: 12px;"/>
                    </VBox>

                    <!-- Cartes info -->
                    <HBox fx:id="infoCardsContainer" spacing="15"/>

                    <!-- Cours + Enseignants -->
                    <HBox spacing="15">
                        <VBox HBox.hgrow="ALWAYS" spacing="12"
                              style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);">
                            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="📅" style="-fx-font-size: 16px;"/>
                                <Label text="Cours du jour"
                                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2c3e6b;"/>
                            </HBox>
                            <VBox fx:id="scheduleContainer" spacing="8"/>
                        </VBox>

                        <VBox prefWidth="350" spacing="12"
                              style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);">
                            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="👥" style="-fx-font-size: 16px;"/>
                                <Label text="Mes enseignants"
                                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2c3e6b;"/>
                            </HBox>
                            <VBox fx:id="teachersContainer" spacing="8"/>
                        </VBox>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>