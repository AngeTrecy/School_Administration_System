<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.school_administration_system.controller.StudentDashboardController"
            style="-fx-background-color: #E2F3FD;">

    <!-- ==================== SIDEBAR ==================== -->
    <left>
        <VBox prefWidth="230" minWidth="230" maxWidth="230" style="-fx-background-color: #304F6D;" spacing="0">

            <!-- Barre titre -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: #243d55; -fx-padding: 12 15 12 15; -fx-min-height: 45; -fx-max-height: 45;">
                <Label text="ÉTUDIANT" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #E6E1DD;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Logo -->
            <VBox alignment="CENTER" spacing="5"
                  style="-fx-min-height: 160; -fx-max-height: 160;">
                <padding><Insets top="15" bottom="15"/></padding>
                <StackPane>
                    <Circle radius="33" style="-fx-fill: transparent; -fx-stroke: #E07D54; -fx-stroke-width: 3;"/>
                    <ImageView fitHeight="110" fitWidth="110" preserveRatio="true">
                        <image>
                            <Image url="@../assets/images/d.png" />
                        </image>
                    </ImageView>
                </StackPane>
            </VBox>

            <!-- Profil étudiant -->
            <VBox alignment="CENTER" spacing="4"
                  style="-fx-padding: 0 10 12 10; -fx-border-color: #3d6080; -fx-border-width: 0 0 1 0;">
                <Label fx:id="welcomeLabel" text="Bonjour !"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label fx:id="dateLabel" text=""
                       style="-fx-font-size: 10px; -fx-text-fill: #bdc3c7; -fx-text-alignment: center;"
                       wrapText="true" maxWidth="180"/>
            </VBox>

            <!-- Menu -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                        style="-fx-background: #304F6D; -fx-background-color: #304F6D; -fx-border-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox spacing="2" style="-fx-background-color: #304F6D; -fx-padding: 8 8 8 8;">

                    <!-- Accueil -->
                    <HBox fx:id="menuAccueil" alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: #E07D54; -fx-cursor: hand; -fx-min-height: 40; -fx-max-height: 40; -fx-background-radius: 8;"
                          onMouseClicked="#handleTableauDeBord">
                        <padding><Insets top="0" right="12" bottom="0" left="14"/></padding>
                        <Label text="🏠" style="-fx-font-size: 14px;"/>
                        <Label text="Accueil" style="-fx-text-fill: white; -fx-font-size: 13px;"/>
                    </HBox>

                    <!-- Ma classe -->
                    <HBox fx:id="menuMaClasse" alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 40; -fx-max-height: 40; -fx-background-radius: 8;"
                          onMouseClicked="#handleMaClasse"
                          onMouseEntered="#handleMenuHover" onMouseExited="#handleMenuExit">
                        <padding><Insets top="0" right="12" bottom="0" left="14"/></padding>
                        <Label text="📖" style="-fx-font-size: 14px;"/>
                        <Label text="Ma classe" style="-fx-text-fill: #E6E1DD; -fx-font-size: 13px;"/>
                    </HBox>

                    <!-- Emploi du temps -->
                    <HBox fx:id="menuEmploi" alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 40; -fx-max-height: 40; -fx-background-radius: 8;"
                          onMouseClicked="#handleEmploiDuTemps"
                          onMouseEntered="#handleMenuHover" onMouseExited="#handleMenuExit">
                        <padding><Insets top="0" right="12" bottom="0" left="14"/></padding>
                        <Label text="📅" style="-fx-font-size: 14px;"/>
                        <Label text="Emploi du temps" style="-fx-text-fill: #E6E1DD; -fx-font-size: 13px;"/>
                    </HBox>

                    <!-- Mes enseignants -->
                    <HBox fx:id="menuEnseignants" alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 40; -fx-max-height: 40; -fx-background-radius: 8;"
                          onMouseClicked="#handleEnseignants"
                          onMouseEntered="#handleMenuHover" onMouseExited="#handleMenuExit">
                        <padding><Insets top="0" right="12" bottom="0" left="14"/></padding>
                        <Label text="👥" style="-fx-font-size: 14px;"/>
                        <Label text="Mes enseignants" style="-fx-text-fill: #E6E1DD; -fx-font-size: 13px;"/>
                    </HBox>

                    <Region VBox.vgrow="ALWAYS"/>

                    <!-- Déconnexion -->
                    <HBox alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 40; -fx-max-height: 40; -fx-background-radius: 8;"
                          onMouseClicked="#handleLogout">
                        <padding><Insets top="0" right="12" bottom="15" left="14"/></padding>
                        <Label text="🚪" style="-fx-font-size: 14px;"/>
                        <Label text="Déconnexion" style="-fx-text-fill: #E07D54; -fx-font-size: 13px;"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </left>

    <!-- ==================== CONTENU PRINCIPAL ==================== -->
    <center>
        <VBox style="-fx-background-color: #E2F3FD;">

            <!-- Barre supérieure -->
            <HBox alignment="CENTER_LEFT" spacing="15"
                  style="-fx-background-color: white; -fx-border-color: #E6E1DD; -fx-border-width: 0 0 1 0;
                         -fx-padding: 0 20 0 28; -fx-min-height: 45; -fx-max-height: 45;">
                <Label fx:id="pageTitle" text="Tableau de bord"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #304F6D;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <StackPane style="-fx-cursor: hand;" onMouseClicked="#handleNotifications">
                    <Label text="🔔" style="-fx-font-size: 18px;"/>
                </StackPane>
                <StackPane style="-fx-cursor: hand;">
                    <Circle radius="16" style="-fx-fill: #E2F3FD;"/>
                    <Label text="👤" style="-fx-font-size: 14px;"/>
                </StackPane>
            </HBox>

            <!-- Zone de contenu dynamique -->
            <ScrollPane fitToWidth="true" fitToHeight="true"
                        style="-fx-background: #E2F3FD; -fx-background-color: #E2F3FD; -fx-border-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <StackPane fx:id="contentArea" style="-fx-background-color: #E2F3FD;">
                    <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
                </StackPane>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>