<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.*?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.school_administration_system.controller.LoginController"
           style="-fx-background-color: #d5d5d5;">

    <!-- Conteneur principal centré -->
    <VBox alignment="CENTER" spacing="0" maxWidth="420" maxHeight="320"
          style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 3);">

        <!-- Barre titre Login -->
        <HBox alignment="CENTER" spacing="10"
              style="-fx-background-color: linear-gradient(to right, #d4edda, #c3e6cb); -fx-background-radius: 8 8 0 0; -fx-padding: 15;">
            <Label text="👤" style="-fx-font-size: 22px;"/>
            <Label text="Login" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #155724;">
                <font>
                    <Font size="22"/>
                </font>
            </Label>
        </HBox>

        <!-- Formulaire -->
        <VBox spacing="20" alignment="CENTER">
            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>

            <!-- Login field -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="Login:" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #333;" prefWidth="90"/>
                <TextField fx:id="loginField" promptText="Enter Email" prefWidth="220" prefHeight="35"
                           style="-fx-background-color: white; -fx-border-color: #ccc; -fx-border-radius: 4; -fx-background-radius: 4; -fx-font-size: 13px;"/>
            </HBox>

            <!-- Password field -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="Password:" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #333;" prefWidth="90"/>
                <PasswordField fx:id="passwordField" promptText="Enter password" prefWidth="220" prefHeight="35"
                               style="-fx-background-color: white; -fx-border-color: #ccc; -fx-border-radius: 4; -fx-background-radius: 4; -fx-font-size: 13px;"/>
            </HBox>

            <!-- Message d'erreur -->
            <Label fx:id="errorLabel" text="" style="-fx-text-fill: #dc3545; -fx-font-size: 12px;" wrapText="true"/>

            <!-- Boutons -->
            <HBox alignment="CENTER" spacing="10">
                <Button text="Cancel" onAction="#handleCancel" prefWidth="90" prefHeight="35"
                        style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 4; -fx-cursor: hand;"/>
                <Button text="Connect" onAction="#handleConnect" prefWidth="90" prefHeight="35"
                        style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 4; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
