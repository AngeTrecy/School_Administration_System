<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.school_administration_system.controller.TeacherDashboardController"
            style="-fx-background-color: #f0f2f5;">

    <!-- ==================== SIDEBAR ==================== -->
    <left>
        <VBox prefWidth="230" minWidth="230" maxWidth="230" style="-fx-background-color: #2c3e6b;" spacing="0">

            <!-- Barre titre -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: #253357; -fx-padding: 12 15 12 15; -fx-min-height: 50; -fx-max-height: 50;">
                <Label text="ENSEIGNANT" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Profil enseignant -->
            <VBox alignment="CENTER" spacing="10"
                  style="-fx-padding: 20 10 16 10; -fx-border-color: #354a7a; -fx-border-width: 0 0 1 0; -fx-min-height: 190;">
                <StackPane>
                    <Circle radius="33" style="-fx-fill: transparent; -fx-stroke: #a855f7; -fx-stroke-width: 3;"/>
                    <ImageView fitHeight="110" fitWidth="110" preserveRatio="true">
                        <image>
                            <Image url="@../assets/images/d.png" />
                        </image>
                    </ImageView>
                </StackPane>
                <Label fx:id="welcomeLabel" text="Bonjour !"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label fx:id="dateLabel" text=""
                       style="-fx-font-size: 10px; -fx-text-fill: #bdc3c7; -fx-text-alignment: center;"
                       wrapText="true" maxWidth="180"/>
            </VBox>

            <!-- Menu -->
            <VBox spacing="2" VBox.vgrow="ALWAYS" style="-fx-background-color: #2c3e6b; -fx-padding: 8 0 0 0;">

                <!-- Accueil -->
                <HBox fx:id="menuAccueil" alignment="CENTER_LEFT" spacing="12"
                      style="-fx-background-color: #7c3aed; -fx-cursor: hand; -fx-min-height: 44; -fx-max-height: 44;"
                      onMouseClicked="#handleTableauDeBord"
                      onMouseEntered="#handleMenuHover" onMouseExited="#handleMenuExit">
                    <padding><Insets top="0" right="15" bottom="0" left="18"/></padding>
                    <Label text="🏠" style="-fx-font-size: 15px;"/>
                    <Label text="Tableau de bord" style="-fx-text-fill: white; -fx-font-size: 13px;"/>
                </HBox>

                <!-- Mon emploi du temps -->
                <HBox fx:id="menuEmploi" alignment="CENTER_LEFT" spacing="12"
                      style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 44; -fx-max-height: 44;"
                      onMouseClicked="#handleMonEmploiDuTemps"
                      onMouseEntered="#handleMenuHover" onMouseExited="#handleMenuExit">
                    <padding><Insets top="0" right="15" bottom="0" left="18"/></padding>
                    <Label text="📅" style="-fx-font-size: 15px;"/>
                    <Label text="Mon emploi du temps" style="-fx-text-fill: #bdc3c7; -fx-font-size: 13px;"/>
                </HBox>

                <!-- Rapports de séance -->
                <HBox fx:id="menuRapports" alignment="CENTER_LEFT" spacing="12"
                      style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 44; -fx-max-height: 44;"
                      onMouseClicked="#handleRapportsDeSeance"
                      onMouseEntered="#handleMenuHover" onMouseExited="#handleMenuExit">
                    <padding><Insets top="0" right="15" bottom="0" left="18"/></padding>
                    <Label text="📋" style="-fx-font-size: 15px;"/>
                    <Label text="Rapports de séance" style="-fx-text-fill: #bdc3c7; -fx-font-size: 13px;"/>
                </HBox>

                <!-- Cahier de texte -->
                <HBox fx:id="menuCahier" alignment="CENTER_LEFT" spacing="12"
                      style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 44; -fx-max-height: 44;"
                      onMouseClicked="#handleCahierDeTexte"
                      onMouseEntered="#handleMenuHover" onMouseExited="#handleMenuExit">
                    <padding><Insets top="0" right="15" bottom="0" left="18"/></padding>
                    <Label text="📝" style="-fx-font-size: 15px;"/>
                    <Label text="Cahier de texte" style="-fx-text-fill: #bdc3c7; -fx-font-size: 13px;"/>
                </HBox>

                <!-- Présences -->
                <HBox fx:id="menuPresences" alignment="CENTER_LEFT" spacing="12"
                      style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 44; -fx-max-height: 44;"
                      onMouseClicked="#handlePresences"
                      onMouseEntered="#handleMenuHover" onMouseExited="#handleMenuExit">
                    <padding><Insets top="0" right="15" bottom="0" left="18"/></padding>
                    <Label text="✅" style="-fx-font-size: 15px;"/>
                    <Label text="Présences" style="-fx-text-fill: #bdc3c7; -fx-font-size: 13px;"/>
                </HBox>

                <!-- Mes classes -->
                <HBox fx:id="menuClasses" alignment="CENTER_LEFT" spacing="12"
                      style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 44; -fx-max-height: 44;"
                      onMouseClicked="#handleMesClasses"
                      onMouseEntered="#handleMenuHover" onMouseExited="#handleMenuExit">
                    <padding><Insets top="0" right="15" bottom="0" left="18"/></padding>
                    <Label text="📖" style="-fx-font-size: 15px;"/>
                    <Label text="Mes classes" style="-fx-text-fill: #bdc3c7; -fx-font-size: 13px;"/>
                </HBox>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Déconnexion -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-background-color: transparent; -fx-cursor: hand; -fx-min-height: 44; -fx-max-height: 44;"
                      onMouseClicked="#handleLogout">
                    <padding><Insets top="0" right="15" bottom="16" left="18"/></padding>
                    <Label text="🚪" style="-fx-font-size: 15px;"/>
                    <Label text="Déconnexion" style="-fx-text-fill: #e74c3c; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <!-- ==================== CONTENU PRINCIPAL ==================== -->
    <center>
        <VBox style="-fx-background-color: #f0f2f5;">

            <!-- Barre supérieure -->
            <HBox alignment="CENTER_LEFT" spacing="15"
                  style="-fx-background-color: white; -fx-border-color: #e9ecef; -fx-border-width: 0 0 1 0;
                         -fx-padding: 0 20 0 28; -fx-min-height: 52; -fx-max-height: 52;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 4, 0, 0, 2);">
                <Label fx:id="pageTitle" text="Tableau de bord"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e6b;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <StackPane style="-fx-cursor: hand;" onMouseClicked="#handleNotifications">
                    <Label text="🔔" style="-fx-font-size: 20px;"/>
                </StackPane>
                <StackPane style="-fx-cursor: hand;" onMouseClicked="#handleProfileMenu">
                    <Circle radius="18" style="-fx-fill: #2c3e6b;"/>
                    <Label text="👤" style="-fx-font-size: 14px;"/>
                </StackPane>
            </HBox>

            <!-- Zone de contenu dynamique -->
            <VBox fx:id="mainContent" spacing="20" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: #f0f2f5;">
                <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>
            </VBox>
        </VBox>
    </center>
</BorderPane>
